/* pages/chat/chat.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f0f0;
}

/* 状态栏 */
.status-bar {
  display: flex;
  align-items: center;
  padding: 8rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.status-dot { font-size: 24rpx; margin-right: 8rpx; }
.status-dot.online  { color: #4caf50; }
.status-dot.offline { color: #aaa; }
.status-text { font-size: 24rpx; color: #666; }

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx 16rpx;
  overflow-y: auto;
}

.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 24rpx;
}
.user-row { flex-direction: row-reverse; }
.ai-row   { flex-direction: row; }

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}
.ai-avatar-text {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}
.user-avatar-text {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
}

/* 气泡 */
.bubble {
  max-width: 68%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-word;
}
.user-bubble {
  background: #1aad19;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}
.ai-bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 4rpx;
}

/* 思考动画 */
.typing-bubble { padding: 20rpx 32rpx; }
.dot {
  font-size: 40rpx;
  color: #aaa;
  animation: blink 1.2s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; }
  40% { opacity: 1; }
}

/* 输入区 */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}
.input-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  font-size: 30rpx;
  min-height: 72rpx;
  max-height: 200rpx;
}
.send-btn {
  margin-left: 16rpx;
  background: #ccc;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  line-height: 1;
}
.send-btn.active {
  background: #1aad19;
}
