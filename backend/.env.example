# .env.example — 复制为 .env 并填写实际值
# cp .env.example .env

# ── OpenClaw ──────────────────────────────
OPENCLAW_HOST=localhost
OPENCLAW_PORT=18789
OPENCLAW_TOKEN=your_openclaw_gateway_token
OPENCLAW_AGENT_ID=main

# ── 后端服务 ──────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── 微信小程序 ────────────────────────────
WX_APPID=your_wx_appid
WX_SECRET=your_wx_appsecret

# ── Session ───────────────────────────────
SESSION_TTL=86400

# ── 日志 ──────────────────────────────────
LOG_LEVEL=INFO
